# Minimum iOS version required by Firebase & all packages we use
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Force dSYM generation for ALL configurations (Debug, Profile, Release).
      # objective_c.framework (Dart FFI) defaults to plain DWARF which omits
      # the .dSYM bundle, failing App Store archive validation with UUID error.
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
      config.build_settings['COPY_PHASE_STRIP'] = 'NO'

      # Exclude *_Test.{h,m} files from geolocator_apple compilation.
      # The umbrella header and module map both reference GeolocationHandler_Test.h
      # and GeolocatorPlugin_Test.h which import <Test/Test.h> (XCTest).
      # XCTest is unavailable in Release/Archive builds, causing a linker error.
      if target.name == 'geolocator_apple'
        config.build_settings['EXCLUDED_SOURCE_FILE_NAMES'] = '*_Test.h *_Test.m'
      end
    end
  end

  # Patch geolocator_apple modulemap — remove the explicit Test module block.
  # CocoaPods generates Target Support Files/geolocator_apple/geolocator_apple.modulemap
  # with an "explicit module Test { ... }" that references GeolocationHandler_Test.h and
  # GeolocatorPlugin_Test.h. Both files import <Test/Test.h> (XCTest) which is not
  # available in Release/Archive builds, failing the linker with a missing framework error.
  geolocator_modulemap = File.join(
    installer.sandbox.root,
    'Target Support Files', 'geolocator_apple', 'geolocator_apple.modulemap'
  )
  if File.exist?(geolocator_modulemap)
    content = File.read(geolocator_modulemap)
    # Remove the entire "explicit module Test { ... }" block
    patched = content.gsub(/\n?\s*explicit module Test \{[^}]*\}\n?/, "\n")
    File.write(geolocator_modulemap, patched) if patched != content
  end

  # Add a build phase to every aggregate target that generates missing dSYMs.
  # This catches any framework whose pod-level setting was overridden by Xcode.
  installer.pods_project.targets.each do |target|
    next unless target.name == 'Pods-Runner'
    phase = target.shell_script_build_phases.find { |p| p.name == 'Generate Missing dSYMs' }
    next if phase
    phase = target.new_shell_script_build_phase('Generate Missing dSYMs')
    phase.shell_script = <<~'BASH'
      find "$BUILT_PRODUCTS_DIR" -name "*.framework" -type d | while read fw; do
        bin="$fw/$(basename "$fw" .framework)"
        [ -f "$bin" ] || continue
        dsym_path="$DWARF_DSYM_FOLDER_PATH/$(basename "$fw").dSYM"
        [ -d "$dsym_path" ] && continue
        echo "Generating dSYM for $(basename "$fw")"
        dsymutil "$bin" -o "$dsym_path" 2>/dev/null || true
      done
    BASH
  end
end
