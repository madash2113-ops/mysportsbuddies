# Copy to .env and fill in your Supabase credentials
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string

SUPABASE_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your-supabase-db-password
